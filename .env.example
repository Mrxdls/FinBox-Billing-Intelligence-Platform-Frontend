# ── FinBox frontend config ──────────────────────────────
# Base URL of the backend API (must include the /api prefix).
# Must match the backend's CLIENT_URL <-> CORS origin pairing.
VITE_API_BASE_URL=http://localhost:4000/api

# URL of the backend's Swagger UI, embedded on the /api-docs page.
VITE_BACKEND_DOCS_URL=http://localhost:4000/api/docs
